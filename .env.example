# Copy to `.env` (`make setup` does this automatically) and customise.

# Optional API troubleshooting: SPA error modal includes full exception dumps when enabled (avoid on untrusted networks).
# Api__ExposeExceptionDetails=true

POSTGRES_PORT=5432
API_PORT=5022
OLLAMA_PORT=11434

# Docker stack job dispatch (API publishes to RabbitMQ; worker consumes).
JOBS_DISPATCH_MODE=RabbitMq
# Worker POSTs progress snapshots here (Docker DNS service name).
JOBS_NOTIFY_API_BASE_URL=http://api:8080/
# Shared secret for POST /internal/jobs/notify (API + worker must match).
JOBS_INTERNAL_NOTIFY_API_KEY=change-me-dev-internal-notify-key

# RabbitMQ broker (management UI published on RABBITMQ_MANAGEMENT_PORT in docker-compose.dev.yml).
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Published ports for RabbitMQ (optional overrides).
# RABBITMQ_PORT=5672
# RABBITMQ_MANAGEMENT_PORT=15672

# Parallel ingest consumers prefetch (worker).
# JOBS_RABBITMQ_GENERAL_PREFETCH=4

# Published port for SPA + `/api` reverse proxy (`spa` container).
WEB_PORT=8080

# NVIDIA GPU: `make setup` probes `docker run --gpus all` and writes `OLLAMA_USE_GPU` (then merges docker-compose.gpu.yml).
# Override manually: OLLAMA_USE_GPU=1 after installing drivers + NVIDIA Container Toolkit.

# Model name passed to Ollama from the API (must match how `ollama list` shows after pull).
OLLAMA_CHAT_MODEL=llama3.2

# Maximum UTF-16 units per Analyze chunk (full stories run many sequential chunks). Raise only if your model/context fits it.
OLLAMA_MAX_CHARS_PER_REQUEST=56000

# Overlap between consecutive chunks (UTF-16 units); reduces missed dialogue at chunk boundaries.
# OLLAMA_ANALYSIS_CHUNK_OVERLAP=640

# Cap on how far backward each chunk may extend to include the previous paragraph / prior ingest segment (UTF-16 units).
# OLLAMA_ANALYSIS_PRIOR_PARAGRAPH_MAX_BACK=24000

# Utterances below this confidence remain eligible for speaker review when not auto-trusted (see below).
# OLLAMA_SPEAKER_REVIEW_THRESHOLD=0.62

# At or above this confidence, a resolved CharacterId clears speaker review; enables fuzzy AI-key → profile name matching.
# OLLAMA_SPEAKER_AUTO_TRUST_THRESHOLD=0.8

# Analysis sampling temperature (0–1). Slightly higher (~0.28) helps gender/voice inference; lower for stricter reproducibility.
OLLAMA_ANALYSIS_TEMPERATURE=0.28

# Persist each structured LLM prompt + assistant JSON for Analyze (Phase 3) and ingest chapter-shift passes.
# Writes to shared Docker volume SmartNarrator storage: App_Data/storage/llm-diagnostics/<jobId>/turns.ndjson
# Available as GET /jobs/<jobId>/llm-diagnostics (API reads the shared volume alongside the worker).
# OLLAMA_CAPTURE_ANALYZE_LLM_TURNS=true
# OLLAMA_ANALYZE_DIAG_MAX_CHARS_PER_FIELD=200000

# Space-separated pulls after `docker compose up` (idempotent). Override to trim disk use.
# Must be quoted (or one tag only) — unquoted spaces break POSIX `source`/`. ./.env` if used.
OLLAMA_PULL_MODELS="llama3.2:latest mistral:7b"

# Optional OpenAI-compatible TTS endpoint (often on the Docker host).
SPEECH_SYNTHESIS_BASE_URI=http://host.docker.internal:8899